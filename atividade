#include <stdio.h>

void main()
{
    for(int x = 1 ; x <= 1000 ; x *= 10){
        printf("%d ",x);
    }
    
    printf("\n");
    
    for(int x = 1000; x > 0 ; x /= 10){ 
        printf("%d ",x);
    } 
    
    printf("\n");
    
    for(int x = 1; x <= 1111; x *= 10, x++) {
        printf("%d ",x);
    }
    
    printf("\n");
    
    for(int x = 1111; x > 0; x--, x /= 10){
        printf("%d ",x);
    }
    
    printf("\n");
    
    for(int x = 1,y = 1; x <= 1111; x *= 10, x++, y++){
        printf("%d ",x*y);  
    } 
    
     printf("\n");
     
    for(int x=1111,y=4;x>0;x--,x/=10,y--){
        printf("%d ",x*y);  
    } 
    
     printf("\n");
     
    for(int x=1;x<=16;x*=-2){
        printf("%d,",x);  
    } 
    
     printf("\n");
     
    for(int x=1,y=10;x<=10;x++,y--){
      printf("%d,%d,",x,y);  
    } 
}
